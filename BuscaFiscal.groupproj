    <Target Name="BuscaFiscalExample:Make">
        <MSBuild Projects="examples\BuscaFiscalExample.dproj" Targets="Make"/>
    </Target>
    <Target Name="Build">
        <CallTarget Targets="BuscaFiscal;BuscaFiscalExample"/>
    </Target>
    <Target Name="Clean">
        <CallTarget Targets="BuscaFiscal:Clean;BuscaFiscalExample:Clean"/>
    </Target>
    <Target Name="Make">
        <CallTarget Targets="BuscaFiscal:Make;BuscaFiscalExample:Make"/>
    </Target>
    <Import Project="$(BDS)\Bin\CodeGear.Group.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Group.Targets')"/>
