<ProjectGroup xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{7512F764-B9D6-4B8F-998C-D13504A7F2A6}</ProjectGuid>
    </PropertyGroup>
    <ItemGroup>
        <Projects Include="packages\delphi\BuscaFiscal.dproj">
            <Dependencies/>
        </Projects>
        <Projects Include="examples\BuscaFiscalExample.dproj">
            <Dependencies/>
        </Projects>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Default.Personality.12</Borland.Personality>
        <Borland.ProjectType/>
        <BorlandProject>
            <Delphi.Personality/>
        </BorlandProject>
    </ProjectExtensions>
    <Target Name="BuscaFiscal">
        <MSBuild Projects="packages\delphi\BuscaFiscal.dproj"/>
    </Target>
    <Target Name="BuscaFiscal:Clean">
        <MSBuild Projects="packages\delphi\BuscaFiscal.dproj" Targets="Clean"/>
    </Target>
    <Target Name="BuscaFiscal:Make">
        <MSBuild Projects="packages\delphi\BuscaFiscal.dproj" Targets="Make"/>
